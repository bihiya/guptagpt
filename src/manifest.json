{
  "manifest_version": 3,
  "name": "Page Capture Extension",
  "version": "1.0.0",
  "description": "Captures active tab HTML and screenshot, then sends to backend.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "commands": {
    "capture-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Capture current tab and send to backend"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://guptagpt-frontend.vercel.app/*"
    ]
  },
  "action": {},
  "side_panel": {
    "default_path": "popup/index.html"
  }
}
